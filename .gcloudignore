# Files Cloud Build does not need to upload. Tightly scoped to keep submit
# fast — only the bits dockerfiles/web.dockerfile actually reads from `web/`
# (and the dockerfile itself) are required.

.git/
.gitignore

# Node + Next caches
node_modules/
**/node_modules/
**/.next/
**/.pnpm-store/
**/dist/
**/build/

# Web app cruft
web/uploads/
web/playwright-report/
web/test-results/
web/coverage/

# Repo-wide cruft
.venv/
**/__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.log
logs/
generated_images/
docs/deep_research/
legacy/

# IDE / OS
.vscode/
.idea/
.DS_Store

# Dev3 artifacts
.dev3.0/
