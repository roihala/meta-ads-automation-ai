# Copy this to `.env` and fill in real values. `.env` is gitignored.
# Production secrets come from Google Secret Manager (see decisions-log §1.1); this file is dev-local only.

# ----- Anthropic -----
# Used by Claude Code CLI (headless) for all agent invocations.
ANTHROPIC_API_KEY=sk-ant-your-dev-key

# ----- GCP / Vertex AI (Imagen image generation) -----
GCP_PROJECT_ID=bemtech-478413
GCP_LOCATION=us-central1
# Authentication uses Application Default Credentials — run once:
#   gcloud auth application-default login
# The compose file mounts ~/.config/gcloud into the container.

# ----- Meta / Facebook Ads -----
META_APP_ID=your-app-id
META_APP_SECRET=your-app-secret
# User token, expires ~60 days. Required scopes:
#   ads_management        — create/update campaigns, adsets, ads, creatives
#   ads_read              — list campaigns/adsets/ads/insights
#   pages_show_list       — resolve Page Access Token via /me/accounts
#   pages_read_engagement — list Page published posts
#   pages_manage_posts    — promote organic posts to ads (future)
#   instagram_basic       — list IG Business media linked to the Page
#   business_management   — Business Manager-scoped resources
# Regenerate at https://developers.facebook.com/tools/explorer/ when scopes change.
# Scopes added in Meta dashboard alone won't take effect — the token must be
# re-issued AFTER the scope is granted.
META_ACCESS_TOKEN=your-access-token
META_AD_ACCOUNT_ID=act_your-account-id   # Must include "act_" prefix
META_PAGE_ID=your-page-id

# ----- Business context -----
BUSINESS_ID=aiweon-uuid                  # Row id in `businesses` collection/table

# ----- Datastore (local dev defaults; docker compose also sets these) -----
# Primary (active): Postgres — local container runs identical engine to Supabase.
# To point at Supabase instead, replace DATABASE_URL with Supabase connection string
# (Project Settings → Database → Connection string → URI). Nothing else changes.
DATABASE_URL=postgresql://campaigner:campaigner_dev_pass@postgres:5432/campaigner_dev

# Legacy scaffolding — kept while decisions-log §1.4 remote target is pending.
# Safe to ignore for Postgres-path workflows.
MONGO_URL=mongodb://mongo:27017
MONGO_DB=campaigner_dev
REDIS_URL=redis://redis:6379/0

# ----- Supabase (remote) — uncomment + fill when promoting to Supabase -----
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# When SUPABASE_URL is set, campaigner/lib/db.py will prefer the Supabase client;
# otherwise it connects directly via DATABASE_URL.
