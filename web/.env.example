# Copy to web/.env.local for local dev. Never commit .env.local.

# ----- Data mode -----
# "local-postgres" (active) | "supabase" (stub; will light up when decisions-log §1.4 resolves)
WEB_DB_MODE=local-postgres

# ----- Local Postgres (when WEB_DB_MODE=local-postgres) -----
# Matches the `postgres` service in docker-compose.yml. Point at host postgres when running outside compose.
DATABASE_URL=postgresql://campaigner:campaigner_dev_pass@postgres:5432/campaigner_dev

# ----- Supabase (when WEB_DB_MODE=supabase; stub today) -----
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ----- Auth mode -----
# "dev-cookie" (active) | "supabase" (stub; paired with WEB_DB_MODE=supabase)
WEB_AUTH_MODE=dev-cookie

# Dev-cookie mode: any email in this allow-list can "log in" without verification.
# Comma-separated. Leave empty to allow any email (dev only).
WEB_DEV_ALLOWED_EMAILS=admin@aiweon.co.il

# ----- Business -----
# Single-business MVP; pinned here so the UI knows which business's rows to show.
BUSINESS_ID=

# ----- Meta integration (see docs/plans/meta-integration-readiness.md) -----
# The web side only uses OAuth. The user-uploaded META_ACCESS_TOKEN path was
# removed — every Meta read now goes through the encrypted OAuth token stored
# in `meta_connections`. (The Python agent under `campaigner/` still reads
# META_ACCESS_TOKEN from the root .env for its cron flows; that's a separate
# refactor.)

# App ID is public, App Secret must come from Secret Manager in prod. App ID
# can sit in plain env.
META_APP_ID=
META_APP_SECRET=

# Public origin — used to build the OAuth redirect URI + webhook callback URLs.
# Dev: http://localhost:3100. Prod: https://app.aiweon.co.il (or whatever the
# live domain is). Must EXACTLY match the URI registered in Meta App Dashboard
# (App Settings → Use Cases → Authenticate → Valid OAuth Redirect URIs).
META_PUBLIC_ORIGIN=http://localhost:3100

# Review tier — drives which scopes are requested at the OAuth dialog.
# 1=Read. 2=Publish. 3=Marketing API write (default). 4=WhatsApp.
# Dev: stay at 3 so the agent's publish + create-campaign capabilities work.
# In dev/standard mode the App owner can grant any scope to their own App
# without App Review, so 3 is safe. Production: bump tier-by-tier as Meta
# approves each use case.
META_REVIEW_TIER=3

# AES-256-GCM key for at-rest token encryption. 32 random bytes, base64-encoded.
# Generate in PowerShell:
#   [Convert]::ToBase64String((1..32 | %{Get-Random -Maximum 256}))
# Or on a Linux/Mac host:
#   openssl rand -base64 32
# In prod, Cloud Run injects this from Secret Manager `meta-encryption-key-v1`.
META_ENCRYPTION_KEY_BASE64=

# HMAC secret for OAuth state tokens (CSRF). Independent rotation from the
# encryption key — leak threat model is different.
#   openssl rand -hex 32
META_STATE_SECRET=
